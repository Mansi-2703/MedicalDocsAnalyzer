# ================================
# MEDICAL DOCUMENT ANALYZER - Environment Configuration
# ================================
# Copy this file to .env and fill in your actual credentials
# IMPORTANT: .env should NEVER be committed to git

# ================================
# 1. GOOGLE GEMINI API (Recommended - Free Tier Available)
# ================================
# Get your free API key at: https://ai.google.dev/
# Steps:
#   1. Go to https://ai.google.dev/
#   2. Click "Get API Key"
#   3. Create new project or select existing
#   4. Generate API key
#   5. Copy and paste below
GEMINI_API_KEY=your_gemini_api_key_here

# ================================
# 2. OPENAI API (Alternative - Paid, $5-20/month typical)
# ================================
# Get your API key at: https://platform.openai.com/api-keys
# Steps:
#   1. Create account at https://openai.com/
#   2. Go to https://platform.openai.com/api-keys
#   3. Create new secret key
#   4. Copy and paste below
# UNCOMMENT TO USE OPENAI:
# OPENAI_API_KEY=sk-your_openai_api_key_here

# ================================
# 3. TESSERACT OCR PATH (Windows/Linux/Mac)
# ================================
# Already configured in config.py for Windows:
# TESSERACT_PATH=C:\Program Files\Tesseract-OCR\tesseract.exe
# 
# If installed elsewhere, uncomment and update:
# TESSERACT_PATH=path/to/tesseract

# ================================
# 4. OPTIONAL: LLM SETTINGS
# ================================
# LLM Provider: gemini, openai, or huggingface
LLM_PROVIDER=gemini

# Gemini model options:
# - gemini-2.0-flash (recommended - fastest & cheapest)
# - gemini-1.5-pro (more capable, slower)
# - gemini-1.5-flash (balanced)
GEMINI_MODEL=gemini-2.0-flash

# OpenAI model options:
# - gpt-4o (most capable, fastest)
# - gpt-4 (capable, slower)
# - gpt-3.5-turbo (faster, cheaper)
# OPENAI_MODEL=gpt-4o

# ================================
# 5. OPTIONAL: DATABASE/STORAGE
# ================================
# For future: result storage, logging, etc.
# DATABASE_URL=sqlite:///./medical_analyzer.db
# LOG_LEVEL=INFO

# ================================
# 6. OPTIONAL: API SETTINGS
# ================================
# API host and port
API_HOST=127.0.0.1
API_PORT=8000

# Enable/disable endpoints
ENABLE_TRAINING_ENDPOINTS=false
ENABLE_ADMIN_ENDPOINTS=false

# ================================
# QUICK START
# ================================
# 1. Copy this file: cp .env.example .env
# 2. Get Gemini API key (FREE): https://ai.google.dev/
# 3. Paste key in .env: GEMINI_API_KEY=...
# 4. Run server: python -m uvicorn src.api.fastapi_app:app --reload
# 5. Visit: http://127.0.0.1:8000/docs
